__pycache__/
*.pyc
*.pyo

# Node / pnpm / turbo
node_modules/
.pnpm-store/
.turbo/
*.log
npm-debug.log*
pnpm-debug.log*

# App build outputs
.next/
apps/*/dist/
apps/*/.next/
apps/*/.astro/
apps/*/out/
apps/desktop/src-tauri/target/
apps/desktop/src-tauri/gen/
packages/*/dist/

# Env
.env
.env.local
.env.*.local

# Egg-info (autogenerated)
src/*.egg-info/

# IDE
.vscode/
.idea/

# Build output
src/loader/build/
src/loader/third_party/*/
!src/loader/third_party/.gitkeep

# Runtime state (written into mods/ at apply time).
# DO NOT add a bare `mods` line here — the example mods under mods/<id>/
# are tracked content and must not be excluded from clones.
mods/_clicks.state
mods/_clicks.log
mods/_persona_map.json
mods/_state.json
mods/_log.txt

# Packed mods + prebuilt loader DLL.
# winhttp.dll is a build artifact shipped via GitHub Releases, not committed.
dist/*.zip
dist/winhttp.dll

# Extracted uncooked game assets (3.2 GB, regenerable via scripts/extract_uncooked.py)
data/uncooked/

# Pattern DB for rsmm.resolve (20 MB, regenerable via scripts/gen_function_patterns.py)
data/function_patterns.json

# Big RE artifacts — Ghidra project itself is committed; outputs are local
docs/_re/out/decompiled_all/
docs/_re/out/xref_targets/
docs/_re/out/symbols.json
docs/_re/out/strings.json
docs/_re/out/functions_index.tsv
docs/_re/out/xref_targets_summary.json
docs/_re/project/
docs/_re/project/
