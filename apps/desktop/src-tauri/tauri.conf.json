{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ravenswatch Mod Manager",
  "version": "0.1.0-4",
  "identifier": "dev.rsmm.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Ravenswatch Mod Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:1420 http://localhost:3001 https://rsmm.dev https://api.ravenswatch.ovilli.de; img-src 'self' data: https:; font-src 'self'; frame-src https://ravenswatch.ovilli.de http://localhost:4321; object-src 'none'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "category": "Utility",
    "shortDescription": "Cross-platform mod manager for Ravenswatch.",
    "longDescription": "A cross-platform mod manager for Ravenswatch. Browse, install, and manage mods through a graphical interface. Swap textures, edit stats, override translations, and author Lua-scripted mods.",
    "externalBin": ["binaries/rsmm"],
    "macOS": {
      "entitlements": "entitlements/macos.entitlements",
      "minimumSystemVersion": "12.0",
      "exceptionDomain": "localhost"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0"]
      },
      "appimage": {
        "bundleMediaFramework": true
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/Ovilli/RavenswatchModManager/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyRkY5REY5NTNBMEU5NjYKUldSbTZhQlQrWjMvd3BpL3lzMENUcHJzUkFGdnpHK3pzWWRkSlVIemxxYWsvS3J2d3k0QW1lVEcK"
    }
  }
}
