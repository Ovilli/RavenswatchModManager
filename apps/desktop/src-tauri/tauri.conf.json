{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ravenswatch Mod Manager",
  "version": "0.0.0",
  "identifier": "dev.rsmm.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:vite",
    "beforeBuildCommand": "pnpm build:vite"
  },
  "app": {
    "windows": [
      {
        "title": "Ravenswatch Mod Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Utility",
    "shortDescription": "Cross-platform mod manager for Ravenswatch."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
