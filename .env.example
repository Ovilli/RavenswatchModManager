# Local Postgres via docker-compose. Override with Neon URL for cloud.
DATABASE_URL=postgres://rsmm:rsmm@localhost:5432/rsmm

# Neon serverless (prod). Toggle driver via DB_DRIVER below.
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/rsmm?sslmode=require

# 'pg' for local docker, 'neon' for Neon serverless HTTP driver.
DB_DRIVER=pg

# Better Auth — generate via: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-32-bytes-hex
BETTER_AUTH_URL=http://localhost:3001

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Desktop (Vite)
VITE_API_URL=http://localhost:3001

# Object storage for mod uploads. Works with S3 + Cloudflare R2 + MinIO.
# Leave blank to disable /mods/upload (returns 503).
S3_BUCKET=
S3_REGION=auto
# R2: https://<account>.r2.cloudflarestorage.com   (leave blank for AWS)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN base, e.g. https://cdn.rsmm.dev. Falls back to bucket URL.
S3_PUBLIC_BASE_URL=
S3_SIGNED_TTL=900
