# Local Postgres via docker-compose. Override with Neon URL for cloud.
POSTGRES_PASSWORD=change-me-local
DATABASE_URL=postgres://rsmm:change-me-local@localhost:5432/rsmm

# Neon serverless (prod). Toggle driver via DB_DRIVER below.
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/rsmm?sslmode=require

# 'pg' for local docker, 'neon' for Neon serverless HTTP driver.
DB_DRIVER=pg

# Better Auth — generate via: openssl rand -hex 32
BETTER_AUTH_SECRET=replace-me-32-bytes-hex
BETTER_AUTH_URL=http://localhost:3001

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Desktop (Vite)
VITE_API_URL=http://localhost:3001

# Object storage for mod uploads. Works with S3 + Cloudflare R2 + MinIO.
# Leave blank to disable /mods/upload (returns 503).
S3_BUCKET=
S3_REGION=auto
# R2: https://<account>.r2.cloudflarestorage.com   (leave blank for AWS)
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public CDN base, e.g. https://cdn.rsmm.dev. Falls back to bucket URL.
S3_PUBLIC_BASE_URL=
S3_SIGNED_TTL=900

# Discord webhook for release notifications (optional, for dev testing)
DISCORD_WEBHOOK_URL=

# Public web URL — used as the verification-email landing target. Set
# to https://ravenswatch.ovilli.de in production.
WEB_URL=http://localhost:3000

# OAuth: Google (Web application credential). Callback:
#   <BETTER_AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth: GitHub. Callback:
#   <BETTER_AUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# SMTP for verification + password-reset emails. Production refuses to
# start without SMTP so users cannot bypass email verification. Local
# development may leave this blank to skip email verification.
#
# IONOS users: SMTP_HOST=smtp.ionos.de (or smtp.ionos.com for .com
# accounts), SMTP_PORT=465 + SMTP_SECURE=true (SSL on 465), or
# SMTP_PORT=587 + SMTP_SECURE=false (STARTTLS). SMTP_USER is the full
# mailbox address, e.g. no-reply@ravenswatch.ovilli.de.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM=no-reply@ravenswatch.ovilli.de
